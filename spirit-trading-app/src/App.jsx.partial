          <button onClick={() => setTab("nouveau")} style={{ background: "linear-gradient(135deg,#00e5a0,#00b37a)", border: "none", color: "#06060f", borderRadius: 22, padding: "8px 18px", fontSize: 12, fontWeight: 800, cursor: "pointer", boxShadow: "0 0 18px rgba(0,229,160,0.3)" }}>
            + {fr ? "Trade" : "Trade"}

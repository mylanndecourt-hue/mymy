    if (impulsifTrades.length > 2 && impulsifPnl < 0) parts.push(`tes ${impulsifTrades.length} trades impulsifs t'ont coÃ»tÃ© ${impulsifPnl.toFixed(0)}$ â€” chaque entrÃ©e non planifiÃ©e est une dÃ©pense, pas un trade`);

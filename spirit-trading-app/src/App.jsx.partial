  let syntheseTexte = "";
  if (pointsForts.length === 0 && pointsAmeliorer.length === 0) {
    syntheseTexte = "Tes rÃ©sultats sont homogÃ¨nes pour l'instant, sans facteur qui se dÃ©marque nettement. Continue Ã  enregistrer tes trades pour affiner l'analyse.";
  } else {
    const partsForts = pointsForts.slice(0, 2).map(i => titreEnPhrase[i.titre] || i.titre.toLowerCase());
    const partsAmeliorer = pointsAmeliorer.slice(0, 2).map(i => titreEnPhrase[i.titre] || i.titre.toLowerCase());
    if (partsForts.length > 0) {
      syntheseTexte += `Ce qui marche bien : ${partsForts.join(" et ")}. `;
    }
    if (partsAmeliorer.length > 0) {
      syntheseTexte += `Ã€ travailler en prioritÃ© : ${partsAmeliorer.join(" et ")}.`;
    } else if (partsForts.length > 0) {
      syntheseTexte += "Continue sur cette voie, aucun point faible majeur ne ressort.";
    }
  }

  // â”€â”€ DonnÃ©es pour les graphiques â”€â”€
  const avgPnlAbs = (arr) => arr.length ? Math.abs(arr.reduce((a, t) => a + t.pnl, 0)) : 0;

  // Camembert : rÃ©partition du P&L total par setup (en valeur absolue, gains + pertes)
  const pieSetup = Object.entries(setupGroups)
    .map(([label, arr]) => ({ label, value: avgPnlAbs(arr) || arr.length }))
    .filter(s => s.value > 0)
    .sort((a, b) => b.value - a.value)
    .slice(0, 6)
    .map((s, i) => ({ ...s, color: CHART_COLORS[i % CHART_COLORS.length] }));

            </div>
          )}
        </Card>
      )}

      {/* â”€â”€ LIGNE 3 : Cercles setup (gauche) | Cercles prop firm (droite) â”€â”€ */}
      {(setupWinRates.length > 0 || propPnl.length > 0) && (
        <div style={{ display: "flex", gap: 14, alignItems: "flex-start" }}>
          {setupWinRates.length > 0 && (
            <Card style={{ flex: 1, minWidth: 0 }}>
              <div style={{ fontSize: 12, fontWeight: 700, color: COLORS.text, marginBottom: 4 }}>ðŸŽ¯ Taux de rÃ©ussite par setup</div>
              <div style={{ fontSize: 10, color: COLORS.muted, marginBottom: 14 }}>Win rate de chaque setup</div>
              <div style={{ display: "flex", flexWrap: "wrap", gap: 12 }}>
                {setupWinRates.map((s, i) => {
                  const r = 36; const circ = 2 * Math.PI * r;
                  const col = s.wr >= 60 ? COLORS.green : s.wr >= 45 ? COLORS.amber : COLORS.red;
                  return (
                    <div key={i} style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 6, minWidth: 88 }}>
                      <div style={{ position: "relative", width: 84, height: 84 }}>
                        <svg width="84" height="84" viewBox="0 0 84 84">
                          <circle cx="42" cy="42" r={r} fill={COLORS.bg} stroke={COLORS.border} strokeWidth="6" />
                          <circle cx="42" cy="42" r={r} fill="none" stroke={col} strokeWidth="6" strokeDasharray={`${(s.wr / 100) * circ} ${circ}`} strokeLinecap="round" transform="rotate(-90 42 42)" style={{ transition: "stroke-dasharray 0.8s ease", filter: `drop-shadow(0 0 4px ${col}80)` }} />
                        </svg>
                        <div style={{ position: "absolute", inset: 0, display: "flex", alignItems: "center", justifyContent: "center" }}>
                          <span style={{ fontSize: 16, fontWeight: 800, fontFamily: "monospace", color: col }}>{s.wr.toFixed(0)}%</span>
                        </div>
                      </div>
                      <div style={{ fontSize: 11, fontWeight: 700, color: COLORS.text, textAlign: "center", lineHeight: 1.3, maxWidth: 80 }}>{s.label}</div>
                      <div style={{ fontSize: 9, color: COLORS.muted }}>{s.count} trades Â· {s.pnl >= 0 ? "+" : ""}{s.pnl.toFixed(0)}$ moy.</div>
                    </div>
                  );
                })}
              </div>
            </Card>
        const bestSetup = setupRanked[0];
        const worstSetup = setupRanked[setupRanked.length - 1];

        // Ã‰motion la plus rentable / pire
        const emMap = {};
        trades.forEach(t => { const ems = t.emotion_avant ? t.emotion_avant.split(", ").filter(Boolean) : []; ems.forEach(em => { if (!emMap[em]) emMap[em] = []; emMap[em].push(t); }); });
        const emRanked = Object.entries(emMap).filter(([,arr])=>arr.length>=2).map(([em, arr]) => ({ em, pnl: arr.reduce((a,t)=>a+t.pnl,0)/arr.length, count: arr.length })).sort((a,b)=>b.pnl-a.pnl);
        const bestEmotion = emRanked[0];
        const worstEmotion = emRanked[emRanked.length - 1];

        // Jour le plus/moins rentable
        const jourGroups = Array.from({ length: 7 }, () => []);
        trades.forEach(t => { if (t.date) jourGroups[getJourIndex(t.date)].push(t); });
        const jourData = jourGroups.map((arr, i) => ({ label: JOURS_FULL[i], pnl: arr.reduce((a,t)=>a+t.pnl,0), count: arr.length })).filter(d => d.count >= 2);
        const bestDay2 = jourData.length ? [...jourData].sort((a,b)=>b.pnl-a.pnl)[0] : null;
        const worstDay2 = jourData.length ? [...jourData].sort((a,b)=>a.pnl-b.pnl)[0] : null;

        // Trades impulsifs
        const impulsifTrades = trades.filter(t => t.impulsif === true || t.impulsif === "true");
        const impulsifPnl = impulsifTrades.reduce((s,t) => s+t.pnl, 0);

        // RÃ¨gles non respectÃ©es
        const violationTrades = trades.filter(t => t.respect === false || t.respect === "false");
        const violationPnl = violationTrades.reduce((s,t) => s+t.pnl, 0);

        // Horaire (si disponible)
        const heureMap = {};
        trades.forEach(t => { if (t.heure) { const h = parseInt(t.heure.split(":")[0]); if (!isNaN(h)) { if (!heureMap[h]) heureMap[h] = []; heureMap[h].push(t); } } });
        const heureRanked = Object.entries(heureMap).filter(([,arr])=>arr.length>=2).map(([h, arr]) => ({ h: parseInt(h), pnl: arr.reduce((a,t)=>a+t.pnl,0), count: arr.length })).sort((a,b)=>b.pnl-a.pnl);
        const bestHeure = heureRanked[0];
        const worstHeure = heureRanked[heureRanked.length - 1];

        const marche = [];
        const arreter = [];
        const ameliorer = [];

        // CE QUI MARCHE
        if (bestSetup && bestSetup.pnl > 0 && bestSetup.wr >= 50) marche.push(`ðŸŽ¯ Setup <strong>${bestSetup.s}</strong> â€” ${bestSetup.wr.toFixed(0)}% WR Â· ${bestSetup.pnl >= 0 ? "+" : ""}${bestSetup.pnl.toFixed(0)}$ sur ${bestSetup.count} trades`);
        if (bestEmotion && bestEmotion.pnl > 0) marche.push(`ðŸ˜Œ Tu trades mieux quand tu es <strong>${bestEmotion.em}</strong> (moy. +${bestEmotion.pnl.toFixed(0)}$ par trade)`);
        if (bestDay2 && bestDay2.pnl > 0) marche.push(`ðŸ“† Le <strong>${bestDay2.label}</strong> est ton meilleur jour (${bestDay2.pnl >= 0 ? "+" : ""}${bestDay2.pnl.toFixed(0)}$ cumulÃ©)`);
        if (bestHeure) marche.push(`ðŸ• Tes meilleures performances sont autour de <strong>${bestHeure.h}h</strong> (${bestHeure.pnl >= 0 ? "+" : ""}${bestHeure.pnl.toFixed(0)}$ Â· ${bestHeure.count} trades)`);
        if (rr >= 1.5) marche.push(`âš–ï¸ Bon ratio risque/rÃ©compense : <strong>${rr.toFixed(2)}R</strong> en moyenne`);
        if (wr >= 55) marche.push(`âœ… Win rate solide Ã  <strong>${wr.toFixed(0)}%</strong>`);

        // CE QU'IL FAUT ARRÃŠTER
        if (worstSetup && worstSetup.pnl < 0 && setupRanked.length > 1) arreter.push(`âŒ Setup <strong>${worstSetup.s}</strong> te coÃ»te ${worstSetup.pnl.toFixed(0)}$ â€” considÃ¨re de l'abandonner`);
        if (worstEmotion && worstEmotion.pnl < -20) arreter.push(`ðŸ˜¤ Ã‰vite de trader quand tu es <strong>${worstEmotion.em}</strong> (moy. ${worstEmotion.pnl.toFixed(0)}$ par trade)`);
        if (worstDay2 && worstDay2.pnl < 0) arreter.push(`ðŸ“† Le <strong>${worstDay2.label}</strong> est ton pire jour (${worstDay2.pnl.toFixed(0)}$ cumulÃ©) â€” envisage de ne pas trader`);
        if (impulsifTrades.length > 0 && impulsifPnl < 0) arreter.push(`âš¡ Trades impulsifs : ${impulsifTrades.length} entrÃ©es pour ${impulsifPnl.toFixed(0)}$ â€” stoppe ces entrÃ©es non planifiÃ©es`);
        if (violationTrades.length > 0 && violationPnl < 0) arreter.push(`ðŸ“œ ${violationTrades.length} trades hors rÃ¨gles pour ${violationPnl.toFixed(0)}$ â€” le respect du plan est non nÃ©gociable`);
        if (worstHeure && worstHeure.pnl < 0 && heureRanked.length > 1) arreter.push(`ðŸ• Ã‰vite de trader autour de <strong>${worstHeure.h}h</strong> (${worstHeure.pnl.toFixed(0)}$ Â· ${worstHeure.count} trades)`);

        // CE Ã€ QUOI S'AMÃ‰LIORER
        if (wr < 50) ameliorer.push(`ðŸ“ˆ Win rate Ã  <strong>${wr.toFixed(0)}%</strong> â€” travaille ta sÃ©lection d'entrÃ©e, moins de trades mais meilleure qualitÃ©`);
        if (rr < 1) ameliorer.push(`âš–ï¸ Ratio R/R Ã  <strong>${rr.toFixed(2)}</strong> â€” coupe les pertes plus tÃ´t ou laisse courir les gains`);
        if (avgLoss > avgWin * 1.2) ameliorer.push(`ðŸ’¸ Tes pertes (moy. -${avgLoss.toFixed(0)}$) dÃ©passent tes gains (moy. +${avgWin.toFixed(0)}$) â€” revois ta gestion du risque`);
        if (impulsifTrades.length / trades.length > 0.2) ameliorer.push(`ðŸ§  ${((impulsifTrades.length/trades.length)*100).toFixed(0)}% de tes trades sont impulsifs â€” intÃ¨gre une checklist avant chaque entrÃ©e`);
        if (setupRanked.length < 3) ameliorer.push(`ðŸŽ¯ Tu utilises peu de setups diffÃ©rents â€” documente mieux chaque entrÃ©e pour identifier tes patterns`);
        if (bestSetup && bestSetup.wr < 60 && bestSetup.pnl > 0) ameliorer.push(`ðŸ”¬ Ton meilleur setup <strong>${bestSetup.s}</strong> est Ã  ${bestSetup.wr.toFixed(0)}% WR â€” cherche Ã  l'affiner pour passer au-dessus de 60%`);

        const Section = ({ title, color, items }) => items.length === 0 ? null : (
          <div style={{ flex: 1, minWidth: 0 }}>
            <div style={{ fontSize: 11, fontWeight: 800, color, marginBottom: 10, letterSpacing: 0.5, textTransform: "uppercase" }}>{title}</div>
            <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
              {items.map((txt, i) => (
                <div key={i} style={{ fontSize: 12, color: COLORS.text, lineHeight: 1.6, padding: "8px 12px", background: color + "0d", borderLeft: `3px solid ${color}50`, borderRadius: "0 6px 6px 0" }} dangerouslySetInnerHTML={{ __html: txt }} />
              ))}
            </div>
          </div>
        );

        return (
          <Card style={{ background: `linear-gradient(135deg, ${COLORS.card}, ${COLORS.card}ee)` }}>
            <div style={{ fontSize: 13, fontWeight: 800, color: COLORS.text, marginBottom: 4 }}>ðŸ§  Diagnostic â€” Ce que disent tes donnÃ©es</div>
            <div style={{ fontSize: 10, color: COLORS.muted, marginBottom: 18 }}>Analyse automatique basÃ©e sur {trades.length} trades enregistrÃ©s</div>
            <div style={{ display: "flex", gap: 20, alignItems: "flex-start", flexWrap: "wrap" }}>
              <Section title="âœ… Ce qui marche" color={COLORS.green} items={marche} />
              <Section title="ðŸ›‘ Ce qu'il faut arrÃªter" color={COLORS.red} items={arreter} />
              <Section title="ðŸ”§ Ce sur quoi s'amÃ©liorer" color={COLORS.amber} items={ameliorer} />
            </div>
            {marche.length === 0 && arreter.length === 0 && ameliorer.length === 0 && (
              <div style={{ color: COLORS.muted, fontSize: 12 }}>Enregistre plus de trades pour obtenir un diagnostic complet.</div>
            )}
          </Card>
        );
      })()}

    </div>
  );
}

// â”€â”€â”€ NOUVEAU TRADE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function NouveauTrade({ onSave, onCancel, comptes = [], editTrade = null }) {
  const defaultCompte = comptes.length > 0 ? comptes[0].nom : "";
  const [form, setForm] = useState(() => {
    if (editTrade) {
      return {
        date: editTrade.date, heure: editTrade.heure, duree: editTrade.duree?.toString() || "",
        compte: editTrade.compte, actif: editTrade.actif, direction: editTrade.direction,
        setup: editTrade.setup, taille: editTrade.taille?.toString() || "",
        pnl: editTrade.pnl?.toString() || "", rr: editTrade.rr?.toString() || "",
        respect: editTrade.respect, regle_violee: editTrade.regle_violee || "", notes_tech: editTrade.notes_tech || "",
        priere: editTrade.priere, heure_coucher: editTrade.heure_coucher || "", sommeil: editTrade.sommeil?.toString() || "",
        ecrans: editTrade.ecrans, qualite_sommeil: editTrade.qualite_sommeil, alimentation: editTrade.alimentation,
        discipline: editTrade.discipline,
        impulsif: editTrade.impulsif,
                <div style={{ fontSize: 20, fontWeight: 800, fontFamily: "monospace", color: COLORS.muted }}>â€”</div>

        {/* EntrÃ©es */}
        <div style={{ background: COLORS.green + "0f", border: `1px solid ${COLORS.green}25`, borderRadius: 10, overflow: "hidden", marginBottom: 10, marginTop: 14 }}>
          <div style={{ padding: "8px 14px", borderBottom: `1px solid ${COLORS.green}20` }}>
            <div style={{ fontSize: 10, fontWeight: 700, color: COLORS.green, textTransform: "uppercase", letterSpacing: 1.5 }}>ðŸ“ˆ EntrÃ©es</div>
          </div>
          <div style={{ display: "flex", justifyContent: "space-between", padding: "10px 14px", background: COLORS.green + "10" }}>
            <span style={{ fontSize: 12, fontWeight: 700, color: COLORS.text }}>Payouts reÃ§us (brut)</span>
            <span style={{ fontFamily: "monospace", fontSize: 14, fontWeight: 800, color: COLORS.green }}>+{totalPayouts}$</span>
          </div>
        </div>

        {/* DÃ©penses */}
        <div style={{ background: COLORS.red + "0f", border: `1px solid ${COLORS.red}25`, borderRadius: 10, overflow: "hidden" }}>
          <div style={{ padding: "8px 14px", borderBottom: `1px solid ${COLORS.red}20` }}>
            <div style={{ fontSize: 10, fontWeight: 700, color: COLORS.red, textTransform: "uppercase", letterSpacing: 1.5 }}>ðŸ“‰ DÃ©penses</div>
          </div>
          {totalPropFirms > 0 && (
            <div style={{ display: "flex", justifyContent: "space-between", padding: "9px 14px", borderBottom: `1px solid ${COLORS.border}` }}>
              <span style={{ fontSize: 12, color: COLORS.textDim }}>Comptes prop firms</span>
              <span style={{ fontFamily: "monospace", fontSize: 13, fontWeight: 700, color: COLORS.red }}>-{totalPropFirms}$</span>
            </div>
          )}
          {totalMQ > 0 && (
            <div style={{ display: "flex", justifyContent: "space-between", padding: "9px 14px", borderBottom: `1px solid ${COLORS.border}` }}>
              <span style={{ fontSize: 12, color: COLORS.textDim }}>MentorQ ({moisMQ} mois)</span>
              <span style={{ fontFamily: "monospace", fontSize: 13, fontWeight: 700, color: COLORS.red }}>-{totalMQ}$</span>
            </div>
          )}
          {totalFraisDivers > 0 && (
            <div style={{ display: "flex", justifyContent: "space-between", padding: "9px 14px", borderBottom: `1px solid ${COLORS.border}` }}>
              <span style={{ fontSize: 12, color: COLORS.textDim }}>Frais divers</span>
              <span style={{ fontFamily: "monospace", fontSize: 13, fontWeight: 700, color: COLORS.red }}>-{totalFraisDivers}$</span>
            </div>
          )}
          {totalDepenses === 0 && (
            <div style={{ padding: "14px", textAlign: "center", color: COLORS.muted, fontSize: 11 }}>Aucune dÃ©pense enregistrÃ©e</div>
          )}
          <div style={{ display: "flex", justifyContent: "space-between", padding: "10px 14px", background: COLORS.red + "10" }}>
            <span style={{ fontSize: 12, fontWeight: 700, color: COLORS.text }}>Total dÃ©penses</span>
            <span style={{ fontFamily: "monospace", fontSize: 14, fontWeight: 800, color: COLORS.red }}>-{totalDepenses}$</span>
          )}
          <div style={{ display: "flex", justifyContent: "space-between", padding: "10px 14px", background: COLORS.red + "10" }}>
            <span style={{ fontSize: 12, fontWeight: 700, color: COLORS.text }}>Total dÃ©penses</span>
            <span style={{ fontFamily: "monospace", fontSize: 14, fontWeight: 800, color: COLORS.red }}>-{totalDepenses}$</span>
          </div>
        </div>
      </Card>


      </div>{/* fin bilan */}

      {/* Fiscal Ã  droite â€” module complet */}
      <div style={{ width: "48%", flexShrink: 0, minWidth: 0 }}>
      {(() => {
        const paysData = PAYS_FISCAL[fiscal.pays];
        const structureData = paysData.structures.find(s => s.id === fiscal.structure);
        const infosAcreRaw = (fiscal.pays === "FR" && structureData?.acre && fiscal.dateCreation) ? getStatutAcre(structureData, fiscal.dateCreation) : null;
        const infosAcre = infosAcreRaw && infosAcreRaw.active ? {
          active: true, tauxReduit: infosAcreRaw.taux,
          tauxExoneration: 1 - (infosAcreRaw.taux / structureData.tauxDefaut),
          finAcre: new Date(infosAcreRaw.finAcre), joursRestants: infosAcreRaw.joursRestants,
        } : (infosAcreRaw ? { active: false, finAcre: new Date(infosAcreRaw.finAcre || fiscal.dateCreation) } : null);
        const tauxEffectif = (infosAcre?.active && fiscal.acreActif) ? infosAcre.tauxReduit : fiscal.taux;
        const impotEstime = fiscal.actif ? (resultatNet > 0 ? resultatNet * (tauxEffectif / 100) : 0) : 0;
        const netApresImpot = resultatNet - impotEstime;
        return (
          <Card style={{ borderLeft: `3px solid ${COLORS.amber}` }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: (fiscal.actif && editingFiscal) ? 14 : (fiscal.actif ? 0 : 4) }}>
              <div>
                <SectionTitle style={{ margin: 0 }}>{structureData.emoji} Structure & fiscalitÃ©</SectionTitle>
                {!fiscal.actif && <div style={{ fontSize: 11, color: COLORS.muted, marginTop: 4 }}>Si ton activitÃ© de trading passe par une entreprise ou micro-entreprise.</div>}
              </div>
              {!fiscal.actif ? (
                <button onClick={() => { setFiscal(f => ({ ...f, actif: true })); setEditingFiscal(true); const dd = PAYS_FISCAL[fiscal.pays]?.deviseFiscale; if (dd && deviseRef === deviseRecue) setDeviseRef(dd); }} style={{ background: COLORS.bg, border: `1px solid ${COLORS.border}`, color: COLORS.muted, borderRadius: 20, padding: "5px 12px", fontSize: 11, fontWeight: 700, cursor: "pointer", flexShrink: 0, marginLeft: 10 }}>Activer</button>
              ) : (
                <button onClick={() => setEditingFiscal(e => !e)} style={{ background: editingFiscal ? COLORS.amber + "20" : COLORS.bg, border: `1px solid ${editingFiscal ? COLORS.amber : COLORS.border}`, color: editingFiscal ? COLORS.amber : COLORS.muted, borderRadius: 20, padding: "5px 12px", fontSize: 11, fontWeight: 700, cursor: "pointer", flexShrink: 0, marginLeft: 10 }}>{editingFiscal ? "âœ• Fermer" : "âœŽ Modifier"}</button>
              )}
            </div>

            {fiscal.actif && !editingFiscal && (
              <div>
                <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 12 }}>
                  <span style={{ fontSize: 22 }}>{paysData.drapeau}</span>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontSize: 13, fontWeight: 800, color: COLORS.text }}>{structureData.emoji} {structureData.label}</div>
                    <div style={{ fontSize: 11, color: COLORS.textDim }}>{paysData.nom}{fiscal.dateCreation ? ` Â· crÃ©Ã©e le ${new Date(fiscal.dateCreation).toLocaleDateString("fr-FR")}` : ""}</div>
                  </div>
                  {infosAcre?.active && fiscal.acreActif && <span style={{ fontSize: 9, fontWeight: 700, color: COLORS.green, background: COLORS.green + "20", border: `1px solid ${COLORS.green}40`, borderRadius: 20, padding: "2px 8px" }}>ðŸŽ‰ ACRE</span>}
                </div>
                <div style={{ background: COLORS.bg, borderRadius: 10, padding: 14 }}>
                  <div style={{ display: "flex", justifyContent: "space-between", padding: "6px 0", borderBottom: `1px solid ${COLORS.border}` }}>
                    <span style={{ fontSize: 12, color: COLORS.textDim }}>RÃ©sultat brut</span>
                    <span style={{ fontSize: 13, fontWeight: 700, fontFamily: "monospace", color: resultatNet >= 0 ? COLORS.green : COLORS.red }}>{resultatNet >= 0 ? "+" : ""}{resultatNet}$</span>
                  </div>
                  <div style={{ display: "flex", justifyContent: "space-between", padding: "6px 0", borderBottom: `1px solid ${COLORS.border}` }}>
                    <span style={{ fontSize: 12, color: COLORS.textDim }}>ImpÃ´t estimÃ© ({tauxEffectif}%)</span>
                    <span style={{ fontSize: 13, fontWeight: 700, fontFamily: "monospace", color: COLORS.red }}>-{impotEstime.toFixed(0)}$</span>
                  </div>
                  <div style={{ display: "flex", justifyContent: "space-between", padding: "8px 0 0" }}>
                    <span style={{ fontSize: 12, fontWeight: 700, color: COLORS.text }}>Net aprÃ¨s impÃ´t</span>
                    <span style={{ fontSize: 16, fontWeight: 800, fontFamily: "monospace", color: netApresImpot >= 0 ? COLORS.green : COLORS.red }}>{netApresImpot >= 0 ? "+" : ""}{netApresImpot.toFixed(0)}$</span>
                  </div>
                </div>
              </div>
            )}

            {fiscal.actif && editingFiscal && (
              <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
                <div>
                  <label style={lbl}>Pays</label>
                  <div style={{ display: "flex", flexWrap: "wrap", gap: 6 }}>
                    {Object.keys(PAYS_FISCAL).map(code => {
                      const p = PAYS_FISCAL[code]; const sel = fiscal.pays === code;
                      return <button key={code} onClick={() => { const ns = p.structures[0]; setFiscal(f => ({ ...f, pays: code, structure: ns.id, taux: ns.tauxDefaut })); if (p.deviseFiscale && deviseRef === deviseRecue) setDeviseRef(p.deviseFiscale); }} style={{ background: sel ? COLORS.amber + "20" : COLORS.bg, border: `1px solid ${sel ? COLORS.amber : COLORS.border}`, color: sel ? COLORS.amber : COLORS.textDim, borderRadius: 8, padding: "7px 12px", fontSize: 12, fontWeight: 700, cursor: "pointer" }}>{p.drapeau} {p.nom}</button>;
                    })}
                  </div>
                </div>
                <div>
                  <label style={lbl}>Type de structure</label>
                  <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                    {paysData.structures.map(s => {
                      const sel = fiscal.structure === s.id;

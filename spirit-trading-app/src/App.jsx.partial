            âœ“ Sauvegarde importÃ©e avec succÃ¨s
          </div>
        )}
        {showImportError && (
          <div style={{ marginTop: 10, background: COLORS.red + "15", border: `1px solid ${COLORS.red}40`, borderRadius: 8, padding: "8px 12px", fontSize: 11, color: COLORS.red, fontWeight: 700 }}>
            âœ• Fichier invalide â€” vÃ©rifie qu'il s'agit bien d'une sauvegarde Spirit Trading
          </div>
        )}
      </div>

      <div style={{ display: "flex", flex: 1 }}>
        {showNav && (
          <div style={{ width: 200, background: COLORS.surface, borderRight: `1px solid ${COLORS.border}`, display: "flex", flexDirection: "column", padding: "12px 8px", gap: 4, position: "sticky", top: 57, height: "calc(100vh - 57px)", overflowY: "auto" }}>
            {tabs.map(t => (
              <button key={t.id} onClick={() => setTab(t.id)} style={{ background: tab === t.id ? COLORS.cyan + "15" : "none", border: tab === t.id ? `1px solid ${COLORS.cyan}30` : "1px solid transparent", color: tab === t.id ? COLORS.cyan : COLORS.muted, cursor: "pointer", display: "flex", alignItems: "center", gap: 10, padding: "10px 12px", borderRadius: 8, fontSize: 13, fontWeight: tab === t.id ? 700 : 400, textAlign: "left", width: "100%" }}>
      {/* â”€â”€ LIGNE 1 : Bilan + Fiscal cÃ´te Ã  cÃ´te â”€â”€ */}
      <div style={{ display: "flex", gap: 14, alignItems: "flex-start" }}>
      <div style={{ flex: 1, minWidth: 0 }}>

      {/* â”€â”€ RÃ‰SULTAT NET GLOBAL â”€â”€ */}
      <Card style={{ borderLeft: `3px solid ${resultatNet >= 0 ? COLORS.green : COLORS.red}` }}>

  const [deviseRecue, setDeviseRecue] = useState("USD");
  const [deviseRef, setDeviseRef] = useState(() => {
    if (fiscal.actif && PAYS_FISCAL[fiscal.pays]?.deviseFiscale) return PAYS_FISCAL[fiscal.pays].deviseFiscale;
    return "USD";
  });

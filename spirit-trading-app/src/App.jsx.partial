        <div style={{ position: "absolute", bottom: 32, left: "50%", transform: "translateX(-50%)", display: "flex", flexDirection: "column", alignItems: "center", gap: 8, opacity: .3, cursor: "pointer" }} onClick={() => scrollRef.current?.scrollTo({ top: window.innerHeight, behavior: "smooth" })}>

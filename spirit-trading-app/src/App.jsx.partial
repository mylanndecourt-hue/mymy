            <div style={{ fontSize: 18, fontWeight: 800, marginBottom: 10 }}>{fr ? "Repartir Ã  zÃ©ro ?" : "Reset all data?"}</div>
            <div style={{ fontSize: 12, color: "#4b5e7a", lineHeight: 1.8, marginBottom: 28 }}>{fr ? "Tous tes trades et donnÃ©es seront supprimÃ©s. Fais d'abord un export JSON." : "All your trades and data will be permanently deleted. Export first."}</div>
            <div style={{ display: "flex", gap: 10 }}>
              <button onClick={() => setShowResetConfirm(false)} style={{ flex: 1, background: "rgba(255,255,255,0.05)", border: "1px solid rgba(255,255,255,0.08)", color: "#e8eaf0", borderRadius: 12, padding: 13, fontSize: 13, fontWeight: 700, cursor: "pointer" }}>{fr ? "Annuler" : "Cancel"}</button>
              <button onClick={handleReset} style={{ flex: 1, background: "rgba(239,68,68,0.15)", border: "1px solid rgba(239,68,68,0.4)", color: "#ef4444", borderRadius: 12, padding: 13, fontSize: 13, fontWeight: 800, cursor: "pointer" }}>ðŸ—‘ï¸ {fr ? "Tout supprimer" : "Delete all"}</button>
            </div>

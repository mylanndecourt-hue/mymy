          </div>
          <div style={{ display: "flex", gap: 6, alignItems: "center", position: "relative" }}>
            <button onClick={() => setShowExportMenu(s => !s)} style={{ background: showExportMenu ? COLORS.cyan + "20" : COLORS.surface, border: `1px solid ${showExportMenu ? COLORS.cyan : COLORS.border}`, color: showExportMenu ? COLORS.cyan : COLORS.textDim, borderRadius: 8, padding: "5px 10px", fontSize: 11, cursor: "pointer", display: "flex", alignItems: "center", gap: 5, fontWeight: 700 }}>
              ðŸ’¾ <span style={{ fontSize: 10 }}>{fr ? "DonnÃ©es" : "Data"}</span>
            </button>
            <button onClick={handleNewCompte} style={{ background: "linear-gradient(135deg,#00e5a0,#00b37a)", border: "none", color: "#06060f", borderRadius: 20, padding: "7px 16px", fontSize: 11, fontWeight: 800, cursor: "pointer", boxShadow: "0 0 16px rgba(0,229,160,0.3)" }}>
              {T.addAccount}
            </button>

            {showExportMenu && (
              <div style={{ position: "absolute", top: "calc(100% + 8px)", right: 0, background: COLORS.card, border: `1px solid ${COLORS.border}`, borderRadius: 10, padding: 8, minWidth: 220, zIndex: 200, boxShadow: "0 8px 24px rgba(0,0,0,0.4)" }}>
                <div style={{ fontSize: 9, color: COLORS.muted, textTransform: "uppercase", letterSpacing: 1.5, padding: "4px 8px 8px" }}>{T.saveData}</div>
                <button onClick={handleLoadDemoData} style={{ width: "100%", textAlign: "left", background: COLORS.cyan + "10", border: "none", color: COLORS.cyan, padding: "10px 8px", fontSize: 12, cursor: "pointer", borderRadius: 6, display: "flex", alignItems: "center", gap: 8, fontWeight: 700 }}>
                  ðŸŽ¯ {fr ? "DonnÃ©es de dÃ©mo (~100 trades)" : "Demo data (~100 trades)"}
                </button>
                <div style={{ height: 1, background: COLORS.border, margin: "4px 0" }} />
                <button onClick={() => { handleExportJSON(); setShowExportMenu(false); }} style={{ width: "100%", textAlign: "left", background: "none", border: "none", color: COLORS.text, padding: "10px 8px", fontSize: 12, cursor: "pointer", borderRadius: 6, display: "flex", alignItems: "center", gap: 8 }}>{T.exportJson}</button>
                <button onClick={() => { handleExportCSV(); setShowExportMenu(false); }} style={{ width: "100%", textAlign: "left", background: "none", border: "none", color: COLORS.text, padding: "10px 8px", fontSize: 12, cursor: "pointer", borderRadius: 6, display: "flex", alignItems: "center", gap: 8 }}>{T.exportCsv}</button>
                <div style={{ height: 1, background: COLORS.border, margin: "4px 0" }} />
                <button onClick={() => { handleImportClick(); setShowExportMenu(false); }} style={{ width: "100%", textAlign: "left", background: "none", border: "none", color: COLORS.cyan, padding: "10px 8px", fontSize: 12, cursor: "pointer", borderRadius: 6, display: "flex", alignItems: "center", gap: 8 }}>{T.importJson}</button>
                <div style={{ fontSize: 9, color: COLORS.muted, padding: "6px 8px 2px", lineHeight: 1.5 }}>{T.csvHint}</div>
                <div style={{ height: 1, background: COLORS.border, margin: "4px 0" }} />
                <button onClick={() => { setShowResetConfirm(true); setShowExportMenu(false); }} style={{ width: "100%", textAlign: "left", background: "none", border: "none", color: COLORS.red, padding: "10px 8px", fontSize: 12, cursor: "pointer", borderRadius: 6, display: "flex", alignItems: "center", gap: 8 }}>
                  ðŸ—‘ï¸ {fr ? "Repartir Ã  zÃ©ro" : "Reset all data"}
                </button>
              </div>
            )}

            <input ref={fileInputRef} type="file" accept="application/json" onChange={handleImportFile} style={{ display: "none" }} />
            <button onClick={toggleLang} style={{ background: "none", border: "none", padding: 0, cursor: "pointer", display: "flex", alignItems: "center", gap: 0 }}>
              <div style={{ display: "flex", alignItems: "center", background: COLORS.surface, border: `1px solid ${COLORS.border}`, borderRadius: 20, overflow: "hidden", gap: 0 }}>
                <div style={{ display: "flex", alignItems: "center", gap: 5, padding: "5px 10px", background: lang === "fr" ? COLORS.cyan + "22" : "transparent", borderRight: `1px solid ${COLORS.border}`, transition: "background 0.2s" }}>
                  <span style={{ fontSize: 14, lineHeight: 1 }}>ðŸ‡«ðŸ‡·</span>
                  <span style={{ fontSize: 10, fontWeight: 800, color: lang === "fr" ? COLORS.cyan : COLORS.muted, letterSpacing: 0.5 }}>FR</span>
                </div>
                <div style={{ display: "flex", alignItems: "center", gap: 5, padding: "5px 10px", background: lang === "en" ? COLORS.cyan + "22" : "transparent", transition: "background 0.2s" }}>
                  <span style={{ fontSize: 14, lineHeight: 1 }}>ðŸ‡¬ðŸ‡§</span>
                  <span style={{ fontSize: 10, fontWeight: 800, color: lang === "en" ? COLORS.cyan : COLORS.muted, letterSpacing: 0.5 }}>EN</span>
                </div>
              </div>
            </button>
            {user && (
              <button onClick={onLogout} title={`ConnectÃ© : ${user.email}`} style={{ background: "none", border: `1px solid ${COLORS.border}`, borderRadius: 8, padding: "6px 10px", cursor: "pointer", display: "flex", alignItems: "center", gap: 6, color: COLORS.muted, fontSize: 11 }}>
                {user.photoURL ? <img src={user.photoURL} alt="" style={{ width: 18, height: 18, borderRadius: "50%" }} /> : "ðŸ‘¤"}
              </button>
            )}
          </div>
        </div>

        {showImportSuccess && (
          <div style={{ marginTop: 10, background: COLORS.green + "15", border: `1px solid ${COLORS.green}40`, borderRadius: 8, padding: "8px 12px", fontSize: 11, color: COLORS.green, fontWeight: 700 }}>{T.importSuccess}</div>
        )}
        {showImportError && (
          <div style={{ marginTop: 10, background: COLORS.red + "15", border: `1px solid ${COLORS.red}40`, borderRadius: 8, padding: "8px 12px", fontSize: 11, color: COLORS.red, fontWeight: 700 }}>{T.importError}</div>
        )}
      </div>

      {showResetConfirm && (
        <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.7)", zIndex: 1000, display: "flex", alignItems: "center", justifyContent: "center" }}>
          <div style={{ background: COLORS.card, border: `1px solid ${COLORS.red}50`, borderRadius: 16, padding: "32px 28px", maxWidth: 360, width: "90%", textAlign: "center" }}>
            <div style={{ fontSize: 36, marginBottom: 12 }}>âš ï¸</div>
            <div style={{ fontSize: 16, fontWeight: 800, color: COLORS.text, marginBottom: 8 }}>{fr ? "Repartir Ã  zÃ©ro ?" : "Reset all data?"}</div>
            <div style={{ fontSize: 12, color: COLORS.muted, lineHeight: 1.6, marginBottom: 24 }}>
              {fr ? "Tous tes trades, comptes et donnÃ©es seront supprimÃ©s dÃ©finitivement. Cette action est irrÃ©versible.\n\nFais d'abord un export JSON pour sauvegarder tes donnÃ©es." : "All your trades, accounts and data will be permanently deleted. This action cannot be undone.\n\nExport a JSON backup first."}
            </div>
            <div style={{ display: "flex", gap: 10 }}>
              <button onClick={() => setShowResetConfirm(false)} style={{ flex: 1, background: COLORS.surface, border: `1px solid ${COLORS.border}`, color: COLORS.text, borderRadius: 10, padding: 12, fontSize: 13, fontWeight: 700, cursor: "pointer" }}>{fr ? "Annuler" : "Cancel"}</button>
              <button onClick={handleReset} style={{ flex: 1, background: COLORS.red + "20", border: `1px solid ${COLORS.red}60`, color: COLORS.red, borderRadius: 10, padding: 12, fontSize: 13, fontWeight: 800, cursor: "pointer" }}>ðŸ—‘ï¸ {fr ? "Tout supprimer" : "Delete all"}</button>
            </div>
          </div>
        </div>
      )}

      <div style={{ display: "flex", flex: 1 }}>
    a.href = url;
    a.download = `spirit-trading-sauvegarde-${dateStr}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };

  const handleExportCSV = () => {
    if (trades.length === 0) return;
    const headers = ["id","date","heure","duree","compte","actif","direction","setup","taille","pnl","rr","respect","regle_violee","notes_tech","priere","heure_coucher","sommeil","ecrans","qualite_sommeil","alimentation","discipline","impulsif","emotion_avant","emotion_pendant","emotion_apres","lecon","note"];
    const escapeCsv = (val) => {
      if (val === null || val === undefined) return "";
      const s = String(val).replace(/"/g, '""');
      return /[",\n;]/.test(s) ? `"${s}"` : s;
    };
    const lines = [headers.join(";")];
    trades.forEach(t => {
      lines.push(headers.map(h => escapeCsv(t[h])).join(";"));
    });
                  }}>
                    <span style={{ fontSize: 16 }}>{t.icon}</span>
                    <span>{T[t.labelKey] || t.labelKey}</span>
                    {isActive && <span style={{ marginLeft: "auto", width: 4, height: 4, borderRadius: "50%", background: "#00e5a0", boxShadow: "0 0 6px #00e5a0" }} />}
                  </button>
                </div>
              );
            })}
          </div>
        )}

        <div style={{ flex: 1, padding: "28px 32px", overflowY: "auto", minWidth: 0, background: "radial-gradient(ellipse at 20% 0%,rgba(0,229,160,0.03) 0%,transparent 60%)" }}>
          {selectedTrade
            ? <DetailTrade trade={selectedTrade} onBack={() => setSelectedTrade(null)} onEdit={handleEditTrade} lang={lang} />
            : tab === "dashboard" ? <Dashboard trades={trades} comptes={comptes} onEditCompte={handleEditCompte} onNewCompte={handleNewCompte} onGoToAnalyse={handleGoToAnalyse} lang={lang} />
            : tab === "session" ? <SessionDuJour sessions={sessions} setSessions={setSessions} lang={lang} />
            : tab === "journal" ? <Journal trades={trades} onNew={() => setTab("nouveau")} onDetail={setSelectedTrade} initialVue={journalInitialVue} lang={lang} />
            : tab === "analyse" ? <AnalysePage trades={trades} comptes={comptes} onDetail={(t) => { setSelectedTrade(t); }} lang={lang} />
            : tab === "nouveau" ? <NouveauTrade onSave={handleSaveTrade} onCancel={handleCancelEdit} comptes={comptes} editTrade={editingTrade} lang={lang} />
            : tab === "ajout_compte" ? <AjoutCompte onSave={handleAddCompte} onCancel={handleCancelCompteEdit} editCompte={editingCompte} onGoToRegles={handleGoToRegles} lang={lang} />
            : tab === "regles" ? <Regles comptes={comptes} preselectedFirm={reglesPreselect} reglesPerso={reglesPerso} setReglesPerso={setReglesPerso} lang={lang} />
            : tab === "objectifs" ? <Objectifs trades={trades} comptes={comptes} objectifs={objectifs} setObjectifs={setObjectifs} lang={lang} />
            : tab === "chemin" ? <LeChemin chapitres={chapitres} setChapitres={setChapitres} lang={lang} />
            : <ROI comptes={comptes} setComptes={setComptes} trades={trades} onEditCompte={handleEditCompte}
                mentorQ={mentorQ} setMentorQ={setMentorQ}
                fraisDivers={fraisDivers} setFraisDivers={setFraisDivers}
                fiscal={fiscal} setFiscal={setFiscal}
                deviseRecue={deviseRecue} setDeviseRecue={setDeviseRecue}
                deviseRef={deviseRef} setDeviseRef={setDeviseRef}
                tauxPerso={tauxPerso} setTauxPerso={setTauxPerso}
                lang={lang}
              />
          }
        </div>
      </div>
    </div>
  );
}


            : tab === "dashboard" ? <Dashboard trades={trades} comptes={comptes} onEditCompte={handleEditCompte} onNewCompte={handleNewCompte} onGoToAnalyse={handleGoToAnalyse} lang={lang} />

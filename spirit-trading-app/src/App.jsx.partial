        {/* Liens landing */}
        <div style={{ display: "flex", gap: 24, alignItems: "center" }}>
          {(fr ? ["ProblÃ¨me","Solution","Modules"] : ["Problem","Solution","Modules"]).map((label, i) => (
            <button key={label} className="spirit-nav-link" onClick={() => scrollRef.current?.scrollTo({ top: (i+1) * window.innerHeight, behavior: "smooth" })}>{label}</button>

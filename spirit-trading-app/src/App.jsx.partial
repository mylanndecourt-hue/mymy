        {trades.length >= 2 ? <PnlCurve trades={trades} height={230} positive={trades.reduce((s, t) => s + t.pnl, 0) >= 0} onTradeClick={onDetail} />
          : <div style={{ height: 130, display: "flex", alignItems: "center", justifyContent: "center", color: COLORS.muted, fontSize: 12 }}>Pas assez de donnÃ©es</div>}
      </Card>
            return (

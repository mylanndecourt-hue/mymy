          </button>

          {user && (
            <button onClick={onLogout} title={user.email} style={{ background: "rgba(255,255,255,0.04)", border: "1px solid rgba(255,255,255,0.07)", borderRadius: 20, width: 34, height: 34, cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center", color: "#8b9ab0", fontSize: 14 }}>
              {user.photoURL ? <img src={user.photoURL} alt="" style={{ width: 22, height: 22, borderRadius: "50%" }} /> : "ðŸ‘¤"}

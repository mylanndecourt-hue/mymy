              <div style={{ position: "absolute", top: "calc(100% + 8px)", right: 0, background: COLORS.card, border: `1px solid ${COLORS.border}`, borderRadius: 10, padding: 8, minWidth: 220, zIndex: 200, boxShadow: "0 8px 24px rgba(0,0,0,0.4)" }}>

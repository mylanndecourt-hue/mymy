      <section className="land-section" style={{ justifyContent: "center", padding: "62px 48px 0", background: "#06060f" }}>
        <div style={{ maxWidth: 1100, width: "100%", margin: "0 auto" }}>
          <div style={{ marginBottom: 56 }}>

    if (impulsifTrades.length / trades.length > 0.15) parts.push(`${((impulsifTrades.length/trades.length)*100).toFixed(0)}% de tes trades sont impulsifs â€” mets en place une <strong>checklist prÃ©-trade</strong> et respecte-la`);

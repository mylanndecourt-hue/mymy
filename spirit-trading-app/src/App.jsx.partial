  const [editingCompte, setEditingCompte] = useState(null); // compte en cours d'Ã©dition, ou null
  const [reglesPreselect, setReglesPreselect] = useState(null); // prop firm Ã  prÃ©sÃ©lectionner dans l'onglet RÃ¨gles

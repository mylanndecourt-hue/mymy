function AnalysePage({ trades, comptes, onDetail }) {
  const MIN_TRADES = 5;

  if (trades.length < MIN_TRADES) {
    return (
      <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
        <Card style={{ textAlign: "center", padding: "40px 20px" }}>
          <div style={{ fontSize: 36, marginBottom: 12 }}>ðŸ”¬</div>
          <div style={{ fontSize: 14, fontWeight: 700, color: COLORS.text, marginBottom: 8 }}>Analyse pas encore disponible</div>
          <div style={{ fontSize: 12, color: COLORS.textDim, lineHeight: 1.6 }}>L'analyse se dÃ©clenche Ã  partir de {MIN_TRADES} trades.</div>
          <div style={{ background: COLORS.bg, borderRadius: 10, padding: 14, maxWidth: 280, margin: "16px auto 0" }}>
            <div style={{ display: "flex", justifyContent: "space-between", fontSize: 11, color: COLORS.textDim, marginBottom: 6 }}><span>Progression</span><span style={{ color: COLORS.cyan, fontWeight: 700 }}>{trades.length} / {MIN_TRADES}</span></div>
            <div style={{ height: 6, background: COLORS.border, borderRadius: 3, overflow: "hidden" }}><div style={{ width: `${Math.min(100, (trades.length / MIN_TRADES) * 100)}%`, height: "100%", background: COLORS.cyan }} /></div>
          </div>
        </Card>
      </div>
    );
  }

  const avgPnl = (arr) => arr.length ? arr.reduce((a, t) => a + t.pnl, 0) / arr.length : 0;
  const winRate = (arr) => arr.length ? (arr.filter(t => t.pnl > 0).length / arr.length) * 100 : 0;
  const avgPnlAbs = (arr) => arr.length ? Math.abs(arr.reduce((a, t) => a + t.pnl, 0)) : 0;
  const overallWR = winRate(trades);
  const overallAvg = avgPnl(trades);

  // Setup groups
  const setupGroups = {};
  trades.forEach(t => { if (!t.setup) return; if (!setupGroups[t.setup]) setupGroups[t.setup] = []; setupGroups[t.setup].push(t); });

  // Emotion groups
  const emotionGroups = {};
  trades.forEach(t => { if (!t.emotion_avant) return; t.emotion_avant.split(", ").forEach(em => { if (!em) return; if (!emotionGroups[em]) emotionGroups[em] = []; emotionGroups[em].push(t); }); });

  // Prop firm groups (par compte)
  const propGroups = {};
  trades.forEach(t => {
    if (!t.compte) return;
    if (!propGroups[t.compte]) propGroups[t.compte] = [];
    propGroups[t.compte].push(t);
  });

  // Taux de rÃ©ussite par setup (cercles)
  const setupWinRates = Object.entries(setupGroups)
    .filter(([_, arr]) => arr.length >= 1)
    .map(([label, arr]) => ({ label, wr: winRate(arr), count: arr.length, pnl: avgPnl(arr) }))
    .sort((a, b) => b.wr - a.wr);

  // P&L par prop firm
  const propPnl = Object.entries(propGroups)
    .map(([label, arr]) => ({ label, total: arr.reduce((a, t) => a + t.pnl, 0), count: arr.length, wr: winRate(arr) }))
    .sort((a, b) => b.total - a.total);
  const maxAbsPropPnl = Math.max(...propPnl.map(p => Math.abs(p.total)), 1);

  // Pie charts
  const pieSetup = Object.entries(setupGroups).map(([label, arr]) => ({ label, value: avgPnlAbs(arr) || arr.length })).filter(s => s.value > 0).sort((a, b) => b.value - a.value).slice(0, 6).map((s, i) => ({ ...s, color: CHART_COLORS[i % CHART_COLORS.length] }));
  const pieEmotion = Object.entries(emotionGroups).map(([label, arr]) => ({ label, value: avgPnlAbs(arr) || arr.length })).filter(s => s.value > 0).sort((a, b) => b.value - a.value).slice(0, 6).map((s, i) => ({ ...s, color: CHART_COLORS[i % CHART_COLORS.length] }));

  // Horaire
  const heureTranches = {};
  trades.filter(t => t.heure).forEach(t => { const h = parseInt(t.heure.split(":")[0]); const tranche = h < 11 ? "Matin <11h" : h < 14 ? "Midi 11-14h" : "AprÃ¨s-midi 14h+"; if (!heureTranches[tranche]) heureTranches[tranche] = []; heureTranches[tranche].push(t); });
  const barWinRateHoraire = Object.entries(heureTranches).filter(([_, arr]) => arr.length >= 2).map(([label, arr]) => ({ label, value: Math.round(winRate(arr)), sub: `${arr.length} trades`, color: winRate(arr) >= 55 ? COLORS.green : winRate(arr) >= 40 ? COLORS.amber : COLORS.red }));

  // Emotion color gradient
  const avgPnlByEm = Object.fromEntries(Object.entries(emotionGroups).map(([em, arr]) => [em, arr.reduce((a, t) => a + t.pnl, 0) / arr.length]));
  const avgEmoValues = Object.values(avgPnlByEm);
  const maxEmoAvg = Math.max(...avgEmoValues), minEmoAvg = Math.min(...avgEmoValues);
  const emotionColorRange = maxEmoAvg - minEmoAvg || 1;
  const emotionColor = (em) => { const t2 = (avgPnlByEm[em] - minEmoAvg) / emotionColorRange; const r2 = Math.round(239 + (34 - 239) * t2); const g2 = Math.round(68 + (197 - 68) * t2); const b2 = Math.round(68 + (94 - 68) * t2); return `rgb(${r2},${g2},${b2})`; };

  // Plan respect
  const planRespecte = trades.filter(t => t.respect === "Oui");
  const pctRespect = trades.length ? Math.round((planRespecte.length / trades.length) * 100) : 0;
  const couleurRespect = pctRespect >= 70 ? COLORS.green : pctRespect >= 45 ? COLORS.amber : COLORS.red;

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>

      {/* â”€â”€ LIGNE 1 : KPI globaux â”€â”€ */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 10 }}>
        {[



        {/* Liens app */}
        <div style={{ display: "flex", gap: 2, flex: 1, overflowX: "auto", scrollbarWidth: "none" }}>
          {APP_SECTIONS.map(s => (
            <button key={s.id} className="spirit-nav-link" onClick={() => scrollToSec(s.ref)} style={{ padding: "0 12px", height: 62, display: "flex", alignItems: "center", gap: 6, whiteSpace: "nowrap" }}>
              <span style={{ fontSize: 14 }}>{s.icon}</span> {s.label}
            </button>
          ))}

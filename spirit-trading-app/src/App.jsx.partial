      setTrades(prev => prev.map(tr => tr.id === editId ? t : tr));
      setEditingTrade(null);
    };
    if (editId) {
      setTrades(prev => prev.map(tr => tr.id === editId ? t : tr));
      setEditingTrade(null);
      setSelectedTrade(t); // retourne sur le dÃ©tail mis Ã  jour
      setTab("journal");
    } else {
      setTrades(prev => [...prev, t]);
      setTab("journal");
    }
  };


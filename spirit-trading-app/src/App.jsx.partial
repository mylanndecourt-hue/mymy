          <button onClick={handleNewCompte} style={{ background: "rgba(255,255,255,0.05)", border: "1px solid rgba(255,255,255,0.08)", color: "#8b9ab0", borderRadius: 22, padding: "7px 14px", fontSize: 12, fontWeight: 600, cursor: "pointer" }}>
            + {fr ? "Compte" : "Account"}
          </button>

          <button onClick={() => setShowExportMenu(s => !s)} style={{ background: showExportMenu ? "rgba(0,229,160,0.1)" : "rgba(255,255,255,0.04)", border: `1px solid ${showExportMenu ? "rgba(0,229,160,0.3)" : "rgba(255,255,255,0.07)"}`, color: showExportMenu ? "#00e5a0" : "#8b9ab0", borderRadius: 8, padding: "7px 12px", fontSize: 11, cursor: "pointer" }}>
            ðŸ’¾
          </button>

          {showExportMenu && (
            <div style={{ position: "absolute", top: "calc(100% + 10px)", right: 0, background: "#0c0c1e", border: "1px solid rgba(255,255,255,0.08)", borderRadius: 14, padding: 8, minWidth: 230, zIndex: 400, boxShadow: "0 20px 50px rgba(0,0,0,.7)" }}>
              <div style={{ fontSize: 9, color: "#4b5e7a", textTransform: "uppercase", letterSpacing: 2, padding: "4px 10px 8px", fontWeight: 700 }}>{T.saveData}</div>
              <button onClick={handleLoadDemoData} style={{ width: "100%", textAlign: "left", background: "rgba(0,229,160,0.07)", border: "none", color: "#00e5a0", padding: "10px 10px", fontSize: 12, cursor: "pointer", borderRadius: 8, display: "flex", alignItems: "center", gap: 8, fontWeight: 700 }}>
                ðŸŽ¯ {fr ? "DonnÃ©es de dÃ©mo (~100 trades)" : "Demo data (~100 trades)"}
              </button>
              <div style={{ height: 1, background: "rgba(255,255,255,0.05)", margin: "5px 0" }} />

        setTimeout(() => setShowImportError(false), 3000);
      }
    };
    reader.readAsText(file);
    e.target.value = ""; // reset pour pouvoir rÃ©importer le mÃªme fichier si besoin
  };

  const tabs = [
    { id: "dashboard", icon: "ðŸ“Š", label: "Dashboard" },
    { id: "journal", icon: "ðŸ“‹", label: "Journal" },
    { id: "chemin", icon: "ðŸªž", label: "Le Chemin" },
    { id: "objectifs", icon: "ðŸŽ¯", label: "Objectifs" },
    { id: "roi", icon: "ðŸ’°", label: "ROI" },
    { id: "regles", icon: "ðŸ“œ", label: "RÃ¨gles" },
  ];


    if (rr >= 1.5) parts.push(`ton ratio risque/rÃ©compense de <strong>${rr.toFixed(2)}R</strong> est bon, tu laisses courir tes gains`);
    if (wr >= 55) parts.push(`avec un win rate de <strong>${wr.toFixed(0)}%</strong> tu gagnes plus de trades que tu n'en perds`);

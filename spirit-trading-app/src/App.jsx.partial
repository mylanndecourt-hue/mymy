                  <button onClick={() => { setFiscal(f => ({ ...f, actif: false })); setEditingFiscal(false); }} style={{ background: COLORS.red + "15", border: `1px solid ${COLORS.red}50`, color: COLORS.red, borderRadius: 20, padding: "5px 10px", fontSize: 13, fontWeight: 700, cursor: "pointer" }}>âœ•</button>

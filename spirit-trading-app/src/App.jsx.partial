    const setups = ["Breakout", "Pullback", "Reversal", "Range", "Scalp", "Swing"];
    const actifs = ["NQ (Nasdaq)", "ES (S&P 500)", "Gold (GC)", "Crude Oil (CL)", "EUR/USD (6E)", "YM (Dow Jones)"];
    const directions = ["LONG", "SHORT"];
    const respects = ["Oui", "Oui", "Oui", "Partiel", "Non"];
    const reglesViolees = ["Stop trop serrÃ©", "EntrÃ©e sans confirmation", "Taille trop grande", "Sorti trop tÃ´t", "Revenge trade"];
    const emotions = ["Serein", "Confiant", "StressÃ©", "Anxieux", "FrustrÃ©", "Euphorique", "En FOMO", "Impatient", "Neutre"];
    const alimentations = ["Saine", "Saine", "Neutre", "Mauvaise"];

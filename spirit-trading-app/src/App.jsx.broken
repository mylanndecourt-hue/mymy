    const onScroll = () => {
      const idx = Math.round(el.scrollTop / window.innerHeight);
      setActiveSection(Math.min(idx, sections.length - 1));
    };
    el.addEventListener("scroll", onScroll, { passive: true });
    return () => el.removeEventListener("scroll", onScroll);
  }, []);

  const scrollTo = (idx) => {

// Mini courbe P&L SVG inline
function PnlCurve({ trades, height = 180, positive }) {
  if (trades.length < 2) return null;

  // Calcul des données
  const cumul = [];
  let sum = 0;
  trades.forEach(t => { sum += t.pnl; cumul.push(sum); });
  const lastVal = cumul[cumul.length - 1];
  const isPositive = positive !== undefined ? positive : lastVal >= 0;
  const color = isPositive ? "#22c55e" : "#ef4444";

  // Dimensions avec marges pour les axes
  const PAD_L = 52, PAD_R = 16, PAD_T = 12, PAD_B = 28;
  const W = 600, H = 180;
  const chartW = W - PAD_L - PAD_R;
  const chartH = H - PAD_T - PAD_B;

  const absMax = Math.max(Math.abs(Math.min(0, ...cumul)), Math.abs(Math.max(0, ...cumul)), 1);
  const minVal = -absMax;
  const maxVal = absMax;
  const range = maxVal - minVal;

  // Points de la courbe
  const pts = cumul.map((v, i) => {
    const x = PAD_L + (i / (cumul.length - 1)) * chartW;
    const y = PAD_T + (1 - (v - minVal) / range) * chartH;
    return [x, y];
  });
  const zeroY = PAD_T + (1 - (0 - minVal) / range) * chartH;
  const linePath = `M ${pts.map(([x,y]) => `${x},${y}`).join(" L ")}`;
  const fillPath = `${linePath} L ${pts[pts.length - 1][0]},${zeroY} L ${pts[0][0]},${zeroY} Z`;

  // Graduations Y (4 lignes)
  const yTicks = 4;
  const yStep = range / yTicks;
  const yLabels = Array.from({ length: yTicks + 1 }, (_, i) => {
    const val = minVal + i * yStep;
    const y = PAD_T + (1 - (val - minVal) / range) * chartH;
    return { val: Math.round(val), y };
  });

  // Labels X : afficher ~5 points réguliers
  const xTickCount = Math.min(5, cumul.length);
  const xLabels = Array.from({ length: xTickCount }, (_, i) => {
    const idx = Math.round(i * (cumul.length - 1) / (xTickCount - 1));
    return { label: `#${idx + 1}`, x: PAD_L + (idx / (cumul.length - 1)) * chartW };
  });

  const GREEN = "#22c55e";
  const RED = "#ef4444";

  return (
    <svg width="100%" viewBox={`0 0 ${W} ${H}`} style={{ display: "block", height }}>
      <defs>
        {/* Clip zone positive (au-dessus de zéro) */}
        <clipPath id="clipPos">
          <rect x={PAD_L} y={PAD_T} width={chartW} height={Math.max(0, zeroY - PAD_T)} />
        </clipPath>
        {/* Clip zone négative (en-dessous de zéro) */}
        <clipPath id="clipNeg">
          <rect x={PAD_L} y={zeroY} width={chartW} height={Math.max(0, PAD_T + chartH - zeroY)} />
        </clipPath>
        {/* Clip général */}
        <clipPath id="chartClip">
          <rect x={PAD_L} y={PAD_T} width={chartW} height={chartH} />
        </clipPath>
        <linearGradient id="fillPos" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={GREEN} stopOpacity="0.18" />
          <stop offset="100%" stopColor={GREEN} stopOpacity="0.02" />
        </linearGradient>
        <linearGradient id="fillNeg" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={RED} stopOpacity="0.02" />
          <stop offset="100%" stopColor={RED} stopOpacity="0.18" />
        </linearGradient>
      </defs>

      {/* Grille horizontale */}
      {yLabels.map((t, i) => (
        <g key={i}>
          <line x1={PAD_L} y1={t.y} x2={W - PAD_R} y2={t.y} stroke="#1e2d45" strokeWidth="1" />
          <text x={PAD_L - 6} y={t.y + 4} textAnchor="end" fontSize="9" fill="#4b5e7a">
            {t.val >= 0 ? "+" : ""}{t.val}$
          </text>
        </g>
      ))}

      {/* Ligne zéro */}
      <line x1={PAD_L} y1={zeroY} x2={W - PAD_R} y2={zeroY} stroke="#4b5e7a" strokeWidth="0.8" strokeDasharray="3,3" opacity="0.7" />

      {/* Remplissage vert (zone positive) */}
      <path d={fillPath} fill="url(#fillPos)" clipPath="url(#clipPos)" />
      {/* Remplissage rouge (zone négative) */}
      <path d={fillPath} fill="url(#fillNeg)" clipPath="url(#clipNeg)" />

      {/* Ligne verte (partie au-dessus de zéro) */}
      <path d={linePath} fill="none" stroke={GREEN} strokeWidth="1.4" strokeLinecap="round" strokeLinejoin="round" clipPath="url(#clipPos)" />
      {/* Ligne rouge (partie en-dessous de zéro) */}
      <path d={linePath} fill="none" stroke={RED} strokeWidth="1.4" strokeLinecap="round" strokeLinejoin="round" clipPath="url(#clipNeg)" />
    </svg>
  );
}

function convertirDevise(montant, deviseSource, deviseCible, tauxPersonnalises = {}) {
  if (deviseSource === deviseCible) return montant;
  const getTaux = (code) => {
    const perso = tauxPersonnalises[code];
    if (typeof perso === "number" && perso > 0) return perso;
    return DEVISES.find(d => d.code === code)?.tauxParDefaut || 1;
  };
  const tauxSource = getTaux(deviseSource); // 1 USD = tauxSource [deviseSource]
  const tauxCible = getTaux(deviseCible);
  const montantEnUSD = montant / tauxSource;
  return montantEnUSD * tauxCible;
}


    { texte: "La joie de l'Éternel sera votre force.", ref: "Néhémie 8:10", label: "🙏 Gratitude" },
    { texte: "Que tout ce qui respire loue l'Éternel !", ref: "Psaume 150:6", label: "🙏 Gratitude" },
